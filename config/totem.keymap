            tapping-term-ms = <RIGHT_PINKY_HOLDING_TIME>;
            quick-tap-ms = <RIGHT_PINKY_REPEAT_DECAY>;
            require-prior-idle-ms = <RIGHT_PINKY_STREAK_DECAY>;
            #binding-cells = <2>;
            bindings = <&kp>, <&right_pinky_tap>;
        };

        #define RightPinkyMiddy right_pinky_middy_bilateral RIGHT_MIDDY_MOD RIGHT_MIDDY_KEY

        // Pinky + Index chord
        right_pinky_index: homey_right_pinky_index {
            compatible = "zmk,behavior-hold-tap";
            flavor = RIGHT_PINKY_HOLDING_TYPE;
            hold-trigger-key-positions = <LEFT_HAND_KEYS THUMB_KEYS>;
            hold-trigger-on-release;
            tapping-term-ms = <RIGHT_PINKY_HOLDING_TIME>;
            quick-tap-ms = <RIGHT_PINKY_REPEAT_DECAY>;
            require-prior-idle-ms = <RIGHT_PINKY_STREAK_DECAY>;
            #binding-cells = <2>;
            bindings = <&kp>, <&kp>;
        };

        right_pinky_index_bilateral: homey_right_pinky_index_bilateral {
            compatible = "zmk,behavior-hold-tap";
            flavor = RIGHT_PINKY_HOLDING_TYPE;
            hold-trigger-key-positions = <LEFT_HAND_KEYS THUMB_KEYS>;
            hold-trigger-on-release;
            tapping-term-ms = <RIGHT_PINKY_HOLDING_TIME>;
            quick-tap-ms = <RIGHT_PINKY_REPEAT_DECAY>;
            require-prior-idle-ms = <RIGHT_PINKY_STREAK_DECAY>;
            #binding-cells = <2>;
            bindings = <&kp>, <&right_pinky_tap>;
        };

        #define RightPinkyIndex right_pinky_index_bilateral RIGHT_INDEX_MOD RIGHT_INDEX_KEY

    };

    combos {
        compatible = "zmk,combos";

        // Q+W = ESC
        combo_esc {
            timeout-ms = <50>;
            key-positions = <0 1>;
            bindings = <&kp ESC>;
        };

        // I+O = Enter
        combo_enter {
            timeout-ms = <50>;
            key-positions = <7 8>;
            bindings = <&kp RET>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        base_layer {
            label= "BASE";
            bindings = <
                          &kp Q                   &kp W                   &kp E                   &kp R                   &kp T                                                       &kp Y               &kp U                 &kp I                 &kp O                 &kp P
                          &LeftPinky(A, BASE)     &LeftRingy(S, BASE)     &LeftMiddy(D, BASE)     &LeftIndex(F, BASE)     &kp G                                                       &kp H               &RightIndex(J, BASE)  &RightMiddy(K, BASE)  &RightRingy(L, BASE)  &RightPinky(SEMI, BASE)
                &kp MINUS &kp Z                   &kp X                   &kp C                   &kp V                   &kp B                                                       &kp N               &kp M                 &kp COMMA             &kp DOT               &kp FSLH                &kp SQT
                                                                                                  &kp LEFT                &lt SYM SPACE       &lt NAV DEL           &lt NAV RET       &lt SYM BSPC        &kp RIGHT
            >;
        };

        nav_layer {
            label= "NAVI";
            bindings = <
                                &none           &none           &kp UP          &none           &kp _CUT                                             &kp KP_NUM      &kp KP_N7       &kp KP_N8       &kp KP_N9       &kp KP_PLUS
                                &none           &kp LEFT        &kp DOWN        &kp RIGHT       &kp _COPY                                            &kp INSERT      &kp KP_N4       &kp KP_N5       &kp KP_N6       &kp KP_MINUS
                &none           &none           &none           &none           &none           &kp _PASTE                                           &kp SLCK        &kp KP_N1       &kp KP_N2       &kp KP_N3       &kp KP_MULTIPLY &kp KP_DIVIDE
                                                                                &trans          &trans          &trans               &mo ADJ         &kp KP_EQUAL    &kp KP_N0
            >;
        };

        sim_layer {
            label= "SYM";
            bindings = <
                                &kp N1          &kp N2          &kp N3          &kp N4          &kp N5                                              &kp N6          &kp N7        &kp N8          &kp N9          &kp N0
                                &none           &kp BSLH        &kp SQT         &trans          &kp LBKT                                            &kp RBKT        &trans        &kp EQUAL       &kp MINUS       &kp GRAVE
                &kp TAB         &kp HOME        &kp END         &kp LEFT        &kp RIGHT       &parang_left                                        &parang_right   &kp UP        &kp DOWN        &kp PG_UP       &kp PG_DN        &euro_symbol
                                                                                &kp CAPS        &trans          &mo ADJ             &mo ADJ         &trans          &kp CAPS
            >;
        };

        adjust_layer {
            label= "ADJ";
            bindings = <
                &sys_reset      &bt BT_CLR      &out OUT_TOG    &trans          &trans              &trans          &kp F7          &kp F8          &kp F9          &kp F12
                &bootloader     &bt BT_NXT      &trans          &trans          &trans              &trans          &kp F4          &kp F5          &kp F6          &kp F11
                &trans          &trans          &bt BT_PRV      &trans          &trans          &trans              &trans          &kp F1          &kp F2          &kp F3          &kp F10         &trans
                                                                &trans          &trans          &trans              &trans          &trans          &trans
            >;
        };

        // Finger layers - activate modifier while tapping keys on same hand
        layer_LeftPinky {
            label= "LPinky";
            bindings = <
                &left_pinky_tap Q  &left_pinky_tap W  &left_pinky_tap E  &left_pinky_tap R  &left_pinky_tap T      &trans  &trans  &trans  &trans  &trans
                &none              &LeftPinkyRingy    &LeftPinkyMiddy    &LeftPinkyIndex    &left_pinky_tap G      &trans  &kp J   &kp K   &kp L   &kp SEMI
                &trans             &left_pinky_tap Z  &left_pinky_tap X  &left_pinky_tap C  &left_pinky_tap V  &left_pinky_tap B      &trans  &trans  &trans  &trans  &trans  &trans
                                                                          &trans             &trans             &trans                 &trans  &trans  &trans
            >;
        };

        layer_LeftRingy {
            label= "LRingy";
            bindings = <
                &left_ringy_tap Q  &left_ringy_tap W  &left_ringy_tap E  &left_ringy_tap R  &left_ringy_tap T      &trans  &trans  &trans  &trans  &trans
                &LeftRingyPinky    &none              &LeftRingyMiddy    &LeftRingyIndex    &left_ringy_tap G      &trans  &kp J   &kp K   &kp L   &kp SEMI
                &trans             &left_ringy_tap Z  &left_ringy_tap X  &left_ringy_tap C  &left_ringy_tap V  &left_ringy_tap B      &trans  &trans  &trans  &trans  &trans  &trans
                                                                          &trans             &trans             &trans                 &trans  &trans  &trans
            >;
        };

        layer_LeftMiddy {
            label= "LMiddy";
            bindings = <
                &left_middy_tap Q  &left_middy_tap W  &left_middy_tap E  &left_middy_tap R  &left_middy_tap T      &trans  &trans  &trans  &trans  &trans
                &LeftMiddyPinky    &LeftMiddyRingy    &none              &LeftMiddyIndex    &left_middy_tap G      &trans  &kp J   &kp K   &kp L   &kp SEMI
                &trans             &left_middy_tap Z  &left_middy_tap X  &left_middy_tap C  &left_middy_tap V  &left_middy_tap B      &trans  &trans  &trans  &trans  &trans  &trans
                                                                          &trans             &trans             &trans                 &trans  &trans  &trans
            >;
        };

        layer_LeftIndex {
            label= "LIndex";
            bindings = <
                &left_index_tap Q  &left_index_tap W  &left_index_tap E  &left_index_tap R  &left_index_tap T      &trans  &trans  &trans  &trans  &trans
                &LeftIndexPinky    &LeftIndexRingy    &LeftIndexMiddy    &none              &left_index_tap G      &trans  &kp J   &kp K   &kp L   &kp SEMI
                &trans             &left_index_tap Z  &left_index_tap X  &left_index_tap C  &left_index_tap V  &left_index_tap B      &trans  &trans  &trans  &trans  &trans  &trans
                                                                          &trans             &trans             &trans                 &trans  &trans  &trans
            >;
        };

        layer_RightPinky {
            label= "RPinky";
            bindings = <
                &trans  &trans  &trans  &trans  &trans      &right_pinky_tap Y  &right_pinky_tap U  &right_pinky_tap I  &right_pinky_tap O  &right_pinky_tap P
                &kp A   &kp S   &kp D   &kp F   &trans      &right_pinky_tap H  &RightPinkyIndex    &RightPinkyMiddy    &RightPinkyRingy    &none
                &trans  &trans  &trans  &trans  &trans  &trans      &right_pinky_tap N  &right_pinky_tap M  &right_pinky_tap COMMA  &right_pinky_tap DOT  &right_pinky_tap FSLH  &trans
                                        &trans  &trans  &trans      &trans              &trans              &trans
            >;
        };

        layer_RightRingy {
            label= "RRingy";
            bindings = <
                &trans  &trans  &trans  &trans  &trans      &right_ringy_tap Y  &right_ringy_tap U  &right_ringy_tap I  &right_ringy_tap O  &right_ringy_tap P
                &kp A   &kp S   &kp D   &kp F   &trans      &right_ringy_tap H  &RightRingyIndex    &RightRingyMiddy    &none               &RightRingyPinky
                &trans  &trans  &trans  &trans  &trans  &trans      &right_ringy_tap N  &right_ringy_tap M  &right_ringy_tap COMMA  &right_ringy_tap DOT  &right_ringy_tap FSLH  &trans
                                        &trans  &trans  &trans      &trans              &trans              &trans
            >;
        };

        layer_RightMiddy {
            label= "RMiddy";
            bindings = <
                &trans  &trans  &trans  &trans  &trans      &right_middy_tap Y  &right_middy_tap U  &right_middy_tap I  &right_middy_tap O  &right_middy_tap P
                &kp A   &kp S   &kp D   &kp F   &trans      &right_middy_tap H  &RightMiddyIndex    &none               &RightMiddyRingy    &RightMiddyPinky
                &trans  &trans  &trans  &trans  &trans  &trans      &right_middy_tap N  &right_middy_tap M  &right_middy_tap COMMA  &right_middy_tap DOT  &right_middy_tap FSLH  &trans
                                        &trans  &trans  &trans      &trans              &trans              &trans
            >;
        };

        layer_RightIndex {
            label= "RIndex";
            bindings = <
                &trans  &trans  &trans  &trans  &trans      &right_index_tap Y  &right_index_tap U  &right_index_tap I  &right_index_tap O  &right_index_tap P
                &kp A   &kp S   &kp D   &kp F   &trans      &right_index_tap H  &none               &RightIndexMiddy    &RightIndexRingy    &RightIndexPinky
                &trans  &trans  &trans  &trans  &trans  &trans      &right_index_tap N  &right_index_tap M  &right_index_tap COMMA  &right_index_tap DOT  &right_index_tap FSLH  &trans
                                        &trans  &trans  &trans      &trans              &trans              &trans
            >;
        };
    };
};
